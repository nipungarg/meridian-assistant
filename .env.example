# Copy to .env and fill in. The provided .env already contains a working OPENAI_API_KEY.
OPENAI_API_KEY=sk-...

# Models (configurable; high-quality chat tier chosen per the plan).
# gpt-4.1 is the default: high quality, supports temperature=0 determinism, strong
# tool-calling/structured-output. Swappable to gpt-5.x (chat-latest variants) if desired.
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Retrieval / reranking
RERANKER=cross_encoder            # cross_encoder | llm | none
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # ~90MB local download, free
RETRIEVAL_TOP_K=10
RERANK_TOP_N=5
MIN_RETRIEVAL_SCORE=0.25          # top embedding-similarity floor; below -> clarify / handoff

# Mock Booking API
BOOKING_API_BASE_URL=http://localhost:8000/v1
BOOKING_API_TOKEN=demo-token

# Demo clock: blank = today's date; set e.g. 2026-01-20 for date-relative demos
DEMO_DATE=
